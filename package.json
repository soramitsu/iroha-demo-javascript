{
  "name": "iroha-demo-javascript",
  "version": "2.0.0",
  "description": "Modernized Torii-connected Iroha point system demo built with Vue 3 and Electron.",
  "author": "gucci-swallow <swallow965dev@gmail.com>",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:vpn:controllers": "node scripts/build-vpn-controllers.mjs",
    "build:vpn:linux-controller": "node scripts/build-vpn-controllers.mjs --platform linux",
    "build:vpn:macos-controller": "node scripts/build-vpn-controllers.mjs --platform darwin",
    "preview": "electron-vite preview",
    "dist": "npm run build && npm run build:vpn:controllers && electron-builder",
    "dist:mac": "npm run build && npm run build:vpn:macos-controller && electron-builder --mac",
    "dist:linux": "npm run build && npm run build:vpn:linux-controller && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs,.vue --max-warnings=0",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:electron",
    "typecheck:renderer": "vue-tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm test",
    "verify:live": "npm run verify && npm run e2e:live",
    "verify:live:vpn-surface": "node scripts/e2e/taira-vpn-surface.mjs",
    "e2e:live": "npm run build && node scripts/e2e/electron-live.mjs",
    "trade:soraswap:live": "node scripts/connect-soraswap-live-trade.mjs",
    "trade:soraswap:perps": "SORASWAP_MODE=perps_open node scripts/connect-soraswap-live-trade.mjs",
    "trade:soraswap:n3x": "SORASWAP_MODE=n3x_mint node scripts/connect-soraswap-live-trade.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@iroha/iroha-js": "file:../iroha/javascript/iroha_js",
    "@scure/bip39": "^2.0.1",
    "@vueuse/core": "^10.11.0",
    "@zxing/browser": "^0.1.5",
    "clsx": "^2.1.1",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.10.2",
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.8",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.5",
    "@vue/tsconfig": "^0.5.1",
    "electron": "^39.1.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.4.5",
    "vite": "^7.2.2",
    "vitest": "^4.0.8",
    "vue-tsc": "^2.0.21"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
