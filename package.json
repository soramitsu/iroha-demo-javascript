{
  "name": "iroha-demo-javascript",
  "version": "2.0.0",
  "description": "Modernized Torii-connected Iroha point system demo built with Vue 3 and Electron.",
  "author": "gucci-swallow <swallow965dev@gmail.com>",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/build-sccp-ton-provers.mjs && node scripts/build-sccp-solana-prover-sidecars.mjs && electron-vite build && node scripts/copy-iroha-native.mjs",
    "build:sccp-ton-provers": "node scripts/build-sccp-ton-provers.mjs",
    "build:sccp-solana-prover-sidecars": "node scripts/build-sccp-solana-prover-sidecars.mjs",
    "build:vpn:controllers": "node scripts/build-vpn-controllers.mjs",
    "build:vpn:linux-controller": "node scripts/build-vpn-controllers.mjs --platform linux",
    "build:vpn:macos-controller": "node scripts/build-vpn-controllers.mjs --platform darwin",
    "preview": "electron-vite preview",
    "dist": "npm run build && npm run build:vpn:controllers && electron-builder",
    "dist:mac": "npm run build && npm run build:vpn:macos-controller && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && npm run build:vpn:linux-controller && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs,.vue --max-warnings=0",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:electron",
    "typecheck:renderer": "vue-tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:coverage": "VITEST_COVERAGE=1 vitest run --pool=threads",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm test",
    "verify:live": "npm run verify && npm run e2e:live",
    "verify:live:vpn-surface": "node scripts/e2e/taira-vpn-surface.mjs",
    "e2e:ui": "node scripts/e2e/ui-smoke.mjs",
    "e2e:live": "npm run build && node scripts/e2e/electron-live.mjs",
    "e2e:explorer": "node scripts/e2e/taira-explorer-smoke.mjs",
    "e2e:sccp:preflight": "node scripts/e2e/sccp-route-preflight.mjs",
    "e2e:sccp:smoke-readiness": "node scripts/e2e/sccp-live-smoke-readiness.mjs",
    "e2e:sccp:bsc-preflight": "node scripts/e2e/sccp-bsc-route-preflight.mjs --check-bsc-contracts true",
    "e2e:sccp:bsc-route-manifest": "node scripts/e2e/sccp-bsc-route-manifest.mjs",
    "e2e:sccp:bsc-runtime-prover-config": "node scripts/e2e/sccp-bsc-runtime-prover-config.mjs",
    "e2e:sccp:bsc-prover-manifest": "node scripts/e2e/sccp-bsc-prover-manifest.mjs",
    "e2e:sccp:bsc-material-inventory": "node scripts/e2e/sccp-bsc-production-material-inventory.mjs",
    "e2e:sccp:bsc-peer-config-audit": "node scripts/e2e/sccp-bsc-peer-config-audit.mjs",
    "e2e:sccp:bsc-smoke-readiness": "node scripts/e2e/sccp-bsc-live-smoke-readiness.mjs",
    "e2e:sccp:bsc-production-gate": "node scripts/e2e/sccp-bsc-production-gate.mjs",
    "e2e:sccp:bsc-video": "node scripts/e2e/sccp-bsc-live-video.mjs",
    "e2e:sccp:ton-preflight": "node scripts/e2e/sccp-ton-route-preflight.mjs",
    "e2e:sccp:ton-video": "node scripts/e2e/sccp-ton-live-video.mjs",
    "e2e:sccp:ton-timing": "node scripts/e2e/sccp-ton-live-video.mjs --duration-ms 3000",
    "e2e:sccp:solana-preflight": "node scripts/e2e/sccp-solana-route-preflight.mjs",
    "e2e:sccp:solana-smoke-readiness": "node scripts/e2e/sccp-solana-live-smoke-readiness.mjs",
    "e2e:sccp:solana-production-gate": "node scripts/e2e/sccp-solana-production-gate.mjs",
    "e2e:sccp:solana-video": "node scripts/e2e/sccp-solana-live-video.mjs",
    "e2e:renderer-protocol": "node scripts/e2e/renderer-protocol-smoke.mjs",
    "e2e:sccp:solana-live-evidence-template": "node scripts/e2e/sccp-solana-live-video.mjs --write-live-evidence-template output/sccp-solana-live-video/completed-solana-bidirectional-live-evidence.template.json",
    "sccp:solana:build-program": "node scripts/build-sccp-solana-programs.mjs all",
    "sccp:solana:build-bridge-program": "node scripts/build-sccp-solana-programs.mjs bridge",
    "sccp:solana:build-native-verifier": "node scripts/build-sccp-solana-programs.mjs native",
    "sccp:solana:build-sbf-validator": "cargo build --release --locked --manifest-path native/solana-sbf-validator/Cargo.toml",
    "verify:sccp-solana-sbf-validator-production": "node scripts/verify-solana-sbf-validator-production.mjs",
    "sccp:solana:deploy": "node scripts/sccp-solana-deploy.mjs",
    "sccp:solana:finalize-programs": "node scripts/sccp-solana-deploy.mjs finalize-programs",
    "sccp:solana:production-material-template": "node scripts/sccp-solana-deploy.mjs production-material-template",
    "sccp:solana:production-material-validate": "node scripts/sccp-solana-deploy.mjs production-material-validate",
    "sccp:solana:finish-production": "node scripts/sccp-solana-deploy.mjs finish-production",
    "sccp:solana:refresh-evidence": "node scripts/sccp-solana-deploy.mjs refresh-evidence",
    "sccp:solana:refresh-live-evidence": "node scripts/sccp-solana-deploy.mjs refresh-evidence --skip-solana-rpc false",
    "sccp:ton:register-taira-vk": "node scripts/register-ton-taira-burn-record-vk.mjs",
    "trade:soraswap:live": "node scripts/connect-soraswap-live-trade.mjs",
    "trade:soraswap:perps": "SORASWAP_MODE=perps_open node scripts/connect-soraswap-live-trade.mjs",
    "trade:soraswap:n3x": "SORASWAP_MODE=n3x_mint node scripts/connect-soraswap-live-trade.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@iroha/iroha-js": "file:../iroha/javascript/iroha_js",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@reown/appkit-universal-connector": "^1.8.20",
    "@scure/bip39": "^2.0.1",
    "@solana/web3.js": "^1.98.4",
    "@ton-community/func-js": "^0.11.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "@tonconnect/sdk": "^4.0.0",
    "@tonconnect/ui": "^3.0.0",
    "@vueuse/core": "^10.11.0",
    "@zxing/browser": "^0.1.5",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@rushstack/eslint-patch": "^1.10.2",
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.8",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.5",
    "@vue/tsconfig": "^0.5.1",
    "electron": "^39.1.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.4.5",
    "vite": "^7.2.2",
    "vitest": "^4.0.8",
    "vue-tsc": "^2.0.21"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soramitsu/iroha-demo-javascript.git"
  },
  "keywords": [],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/soramitsu/iroha-demo-javascript/issues"
  },
  "homepage": "https://github.com/soramitsu/iroha-demo-javascript#readme"
}
