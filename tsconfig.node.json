{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": [
    "electron/**/*.ts",
    "src/**/*.d.ts",
    "src/utils/accountId.ts",
    "src/utils/assetId.ts",
    "src/utils/chainMetadata.ts",
    "src/utils/confidential.ts",
    "src/utils/errorMessage.ts",
    "src/utils/mnemonic.ts",
    "src/utils/secretLike.ts",
    "src/utils/sccpDataSnapshot.ts",
    "src/utils/sccpProverUrl.ts",
    "src/utils/signingAlgorithms.ts",
    "src/utils/soracloud.ts",
    "src/utils/transactionFee.ts",
    "src/utils/walletBackup.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@iroha/iroha-js": [
        "node_modules/.cache/iroha-sdk-compat/active/index.d.ts"
      ],
      "@iroha/iroha-js/address": [
        "node_modules/.cache/iroha-sdk-compat/active/index.d.ts"
      ],
      "@iroha/iroha-js/connect-browser": [
        "node_modules/.cache/iroha-sdk-compat/active/connect.browser.d.ts"
      ],
      "@iroha/iroha-js/crypto": [
        "node_modules/.cache/iroha-sdk-compat/active/index.d.ts"
      ],
      "@iroha/iroha-js/sccp": [
        "node_modules/.cache/iroha-sdk-compat/active/index.d.ts"
      ]
    }
  }
}
